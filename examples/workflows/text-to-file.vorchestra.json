{
  "schemaVersion": 2,
  "id": "text-to-file",
  "name": "Text to file with tee",
  "inputs": [
    {
      "id": "content",
      "name": "Content to append",
      "artifactKind": "text",
      "required": true
    }
  ],
  "inputBindings": [
    {
      "id": "content-to-tee",
      "inputId": "content",
      "to": {
        "blockId": "append-file",
        "portId": "content"
      }
    }
  ],
  "blocks": [
    {
      "id": "append-file",
      "name": "Append with tee",
      "kind": "process",
      "inputs": [
        {
          "id": "content",
          "name": "Content",
          "artifactKind": "text",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "echoed",
          "name": "Echoed text",
          "artifactKind": "text"
        },
        {
          "id": "file",
          "name": "Generated file",
          "artifactKind": "filesystem-reference"
        }
      ],
      "invocation": {
        "executable": "tee",
        "arguments": [
          {
            "type": "literal",
            "value": "-a"
          },
          {
            "type": "literal",
            "value": "./vorchestra-output.txt"
          }
        ],
        "environment": {
          "PATH": {
            "source": "host",
            "name": "PATH"
          }
        },
        "stdin": {
          "portId": "content"
        },
        "shell": false,
        "outputs": [
          {
            "type": "stdout",
            "portId": "echoed"
          },
          {
            "type": "filesystem",
            "portId": "file",
            "path": "./vorchestra-output.txt",
            "entity": "file"
          }
        ]
      }
    },
    {
      "id": "count-file",
      "name": "Count generated bytes",
      "kind": "process",
      "inputs": [
        {
          "id": "file",
          "name": "Generated file",
          "artifactKind": "filesystem-reference",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "count",
          "name": "Byte count",
          "artifactKind": "text"
        }
      ],
      "invocation": {
        "executable": "wc",
        "arguments": [
          {
            "type": "literal",
            "value": "-c"
          },
          {
            "type": "input",
            "portId": "file"
          }
        ],
        "environment": {
          "PATH": {
            "source": "host",
            "name": "PATH"
          }
        },
        "shell": false,
        "outputs": [
          {
            "type": "stdout",
            "portId": "count"
          }
        ]
      }
    }
  ],
  "connections": [
    {
      "id": "file-to-count",
      "from": {
        "blockId": "append-file",
        "portId": "file"
      },
      "to": {
        "blockId": "count-file",
        "portId": "file"
      }
    }
  ],
  "layout": {
    "blockPositions": {
      "append-file": {
        "x": 160,
        "y": 160
      },
      "count-file": {
        "x": 520,
        "y": 160
      }
    }
  }
}
